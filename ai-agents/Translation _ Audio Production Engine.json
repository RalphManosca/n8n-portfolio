    {
      "parameters": {
        "jsCode": "// n8n Code Node - Split Script into Sentences\n\n// Get the input data\nconst inputData = $input.first().json['Scripts in German'];\n\n// Function to split text into sentences\nfunction splitIntoSentences(text) {\n  // Sentence splitting - handles common abbreviations and patterns\n  const sentences = text\n    .replace(/([.!?])\\s+/g, '$1|SPLIT|') // Mark sentence boundaries\n    .replace(/([.!?])$/g, '$1|SPLIT|') // Handle end of text\n    .split('|SPLIT|')\n    .map(s => s.trim())\n    .filter(s => s.length > 0); // Remove empty strings\n  \n  return sentences;\n}\n\n// Function to generate a unique ID\nfunction generateId(index) {\n  return `position_${index + 1}`;\n}\n\n// Process the first item in the input\nconst scriptText = inputData;\n\nif (!scriptText) {\n  return [{\n    json: {\n      error: 'No \"Scripts in German\" field found'\n    }\n  }];\n}\n\n// Split the script into sentences\nconst sentences = splitIntoSentences(scriptText);\n\n// Return array of items, each with a sentence object\nreturn sentences.map((sentence, index) => ({\n  json: {\n    id: generateId(index),\n    sentence: sentence\n  }\n}));"
      },
