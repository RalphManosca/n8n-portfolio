    {
      "parameters": {
        "jsCode": "// Create 3 items for TTS processing\nconst items = [];\nconst sentence = $input.first().json.sentence;\nconst sentenceId = $input.first().json.id;\n\nfor (let i = 1; i <= 3; i++) {\n  let rate = 1.0;\n  \n  switch(i) {\n    case 2:\n      rate = 0.95;\n      break;\n    case 3:\n      rate = 1.05;\n      break;\n  }\n  \n  items.push({\n    json: {\n      id: sentenceId,\n      sentence: sentence,\n      sample_number: i,\n      filename: `scene_${sentenceId}_voiceover_v${i}`,\n      speaking_rate: rate\n    }\n  });\n}\n\nconst loopData = $('Loop for Sentences').first().json\n\nreturn [{\n  items,\n  id: loopData.id,\n  sentence: loopData.sentence,\n  record_id: $('Get Script').first().json.id\n}];"
      },
