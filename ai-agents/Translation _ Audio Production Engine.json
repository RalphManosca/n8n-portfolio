        "jsCode": "const allItems = $input.all();\n\nconst urls = [];\n\nfor (const item of allItems) {\n  if (item.json.webViewLink) {\n    urls.push(item.json.webViewLink);\n  } else if (item.json.webContentLink) {\n    urls.push(item.json.webContentLink);\n  }\n}\n\nconst loopData = $('Psuedo Loop').first().json;\nconst translatedData = $('Claude Translator DE to EN').first().json;\n\nreturn [{\n  id: loopData.id,\n  sentence: loopData.sentence,\n  all_audio_urls: urls.join(', '),\n  sentence_english: translatedData.output\n}];"
